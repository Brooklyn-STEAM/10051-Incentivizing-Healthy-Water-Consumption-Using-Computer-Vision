<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white min-h-screen flex flex-col items-center">
  {% include "components/navbar.html.jinja" %}
 
  <section class="max-w-4xl w-full px-6 py-10 bg-blue-200 rounded-lg shadow mt-10 text-center">
      <h1 class="text-3xl font-bold mt-4">Daily Drip</h1>

      <!-- Updated points element so JS can update it -->
      <p class="mt-2 text-lg points-display">Points: {{ points }}</p>

      <!-- MACHINE -->
      <div class="mt-6 relative">
          <img src="{{ url_for('static', filename='machine.png') }}" 
               class="w-80 mx-auto animate-pulse">
      </div>

      <!-- BUTTONS -->
      <div class="flex gap-4 mt-6 text-center justify-center">
          <button onclick="spin(1)"
              class="bg-yellow-200 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105">
              10 Points • 1 Pull
          </button>

          <button onclick="spin(10)"
              class="bg-yellow-200 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105">
              50 Points • 10 Pulls
          </button>
      </div>
  </section>

  <!-- RESULT MODAL -->
  <div id="resultModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">
      <div class="bg-blue-200 p-6 rounded-xl text-center max-w-md w-full">
          <h2 class="text-xl font-bold mb-4">You Won!</h2>

          <!-- MULTIPLE REWARDS (populated by JS) -->
          <div id="rewardList" class="grid grid-cols-2 gap-4"></div>

          <button onclick="closeModal()"
              class="mt-4 bg-blue-400 px-4 py-2 rounded text-white font-bold">
              Close
          </button>
      </div>
  </div>

  <!-- REWARD CATALOG -->
  <main class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-2 gap-10 rounded-lg shadow mt-10 w-full bg-blue-200">
      <h2 class="text-xl font-bold mb-4 text-center justify-center">All Rewards</h2>

      <div class="flex justify-center gap-5 flex-wrap col-span-full bg-blue-200">
          {% for reward in rewards %}
          <a href="/reward/{{ reward.ID }}" class="bg-white rounded-lg shadow p-4 w-48 mx-2 hover:scale-105 transition">
              <img src="{{ reward.Image }}" class="w-full h-24 object-cover rounded" alt="{{ reward.Name }}">
              <p class="text-center mt-2 text-sm font-bold">{{ reward.Name }}</p>
          </a>
          {% endfor %}
      </div>
  </main>

  <!-- Server-rendered user rewards + container for immediate spin results -->
  <div class="max-w-6xl mx-auto px-6 py-6 w-full">
    <h3 class="text-lg font-bold mb-3">Your Rewards</h3>

    <div id="user-rewards-container" class="flex gap-4 flex-wrap">
      {% for ur in user_rewards %}
        <div class="reward-card bg-white rounded-lg shadow p-3 w-40 text-center" data-ur-id="{{ ur.ur_id }}">
          {% if ur.Image %}
            {% if ur.Image.startswith('/static/') %}
              <img src="{{ ur.Image }}" alt="{{ ur.Name }}" class="w-full h-24 object-cover rounded reward-image">
            {% else %}
              <img src="{{ url_for('static', filename=ur.Image) }}" alt="{{ ur.Name }}" class="w-full h-24 object-cover rounded reward-image">
            {% endif %}
          {% else %}
            <img src="{{ url_for('static', filename='placeholder.png') }}" alt="No image" class="w-full h-24 object-cover rounded reward-image">
          {% endif %}
          <div class="reward-name mt-2 font-bold text-sm">{{ ur.Name }}</div>
        </div>
      {% endfor %}
    </div>

    <!-- Container for immediate spin results (cleared and filled by JS) -->
    <div id="spin-results" class="spin-results mt-6 flex gap-4 flex-wrap"></div>
  </div>

  <style>
    .spin-results { display:flex; gap:12px; flex-wrap:wrap; margin-top:12px; }
    .reward-card { width:140px; text-align:center; }
    .reward-image { width:100%; height:auto; border-radius:8px; display:block; }
    .reward-name { margin-top:6px; font-size:14px; }
  </style>

  <script>
  // Convert DB image path to usable URL
  function imageUrl(path) {
    if (!path) return '/static/placeholder.png';
    if (path.startsWith('/static/') || path.startsWith('http://') || path.startsWith('https://')) {
      return path;
    }
    // treat as static filename
    return '/static/' + path.replace(/^\/+/, '');
  }

  // Populate modal with returned rewards and open it
  function openModalWithRewards(rewards) {
    const list = document.getElementById("rewardList");
    list.innerHTML = "";
    if (!rewards || rewards.length === 0) {
      list.textContent = "No rewards";
      return;
    }
    rewards.forEach(r => {
      const item = document.createElement("div");
      item.className = "flex flex-col items-center";

      const img = document.createElement("img");
      img.src = imageUrl(r.Image);
      img.className = "w-20 h-20 object-cover rounded mb-2";
      img.alt = r.Name || '';

      const name = document.createElement("p");
      name.className = "font-bold text-sm";
      name.textContent = r.Name || 'Unknown';

      item.appendChild(img);
      item.appendChild(name);
      list.appendChild(item);
    });

    document.getElementById("resultModal").classList.remove("hidden");
  }

  // Update points display element
  function updatePointsDisplay(remaining) {
    const el = document.querySelector('.points-display');
    if (el) el.textContent = 'Points: ' + remaining;
  }

  // Main spin function called by buttons
  async function spin(amount) {
    try {
      // disable buttons while request is in-flight
      const btns = document.querySelectorAll('button[onclick^="spin("]');
      btns.forEach(b => b.disabled = true);

      const resp = await fetch("/gacha_spin", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify({ plays: amount })
      });

      if (!resp.ok) {
        const text = await resp.text();
        throw new Error('Server error: ' + resp.status + ' ' + text);
      }

      const data = await resp.json();
      if (!data.success) throw new Error(data.message || 'Spin failed');

      // show returned images immediately in modal
      openModalWithRewards(data.rewards || []);
      updatePointsDisplay(data.remaining_points);

      // Optionally also append the new rewards to the user-rewards container
      // so they appear in the "Your Rewards" list without a page reload:
      const userContainer = document.getElementById('user-rewards-container');
      if (userContainer && data.rewards && data.rewards.length) {
        data.rewards.forEach(r => {
          const card = document.createElement('div');
          card.className = 'reward-card bg-white rounded-lg shadow p-3 w-40 text-center';
          const imgSrc = imageUrl(r.Image);
          card.innerHTML = `
            <img src="${imgSrc}" alt="${r.Name || ''}" class="w-full h-24 object-cover rounded reward-image">
            <div class="reward-name mt-2 font-bold text-sm">${r.Name || ''}</div>
          `;
          // prepend newest reward
          userContainer.insertBefore(card, userContainer.firstChild);
        });
      }

    } catch (err) {
      console.error('Gacha spin error', err);
      alert('Spin failed: ' + (err.message || 'Unknown error'));
    } finally {
      const btns = document.querySelectorAll('button[onclick^="spin("]');
      btns.forEach(b => b.disabled = false);
    }
  }

  function closeModal() {
    document.getElementById("resultModal").classList.add("hidden");
  }

  // wire close button (keeps existing onclick but ensures event binding)
  document.addEventListener('DOMContentLoaded', function () {
    const closeBtn = document.querySelector('#resultModal button');
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
  });
  </script>

</body>
</html>
