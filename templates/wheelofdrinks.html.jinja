
<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>

<title>Waterly Drink Machine</title>

</head>

<body 
	class="
		bg-blue-50 
		flex 
		flex-col 
		items-center 
		justify-center 
		min-h-screen 
		gap-6
	">

{% include "components/navbar.html.jinja" ignore missing %}

<h1 class="text-3xl font-bold text-blue-700">
Waterly Drink Machine
</h1>

<p class="text-xl">
Your Points: <span class="font-bold text-blue-600">{{ coins | default(0) }}</span>
</p>

<div class="machine">
<img src="{{ url_for('static', filename='machine.png') }}" class="w-72" onerror="this.src='/static/fallback.png';">
</div>

<div class="flex gap-4">

<button onclick="spin(1)" class="bg-blue-500 text-white px-4 py-2 rounded">
10 Points • 1 Pull
</button>

<button onclick="spin(5)" class="bg-blue-500 text-white px-4 py-2 rounded">
50 Points • 5 Pulls
</button>

<button onclick="spin(10)" class="bg-blue-500 text-white px-4 py-2 rounded">
100 Points • 10 Pulls
</button>

</div>

<script>

function spin(amount){

fetch("/gacha_spin",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({
plays:amount
})
})
.then(res => {
if (!res.ok) {
throw new Error("Network response was not ok");
}
return res.json();
})
.then(data => {

if(data.success){
window.location.href="/results"
}
else{
alert(data.message);
}

})
.catch(error => {
alert("An error occurred: " + error.message);
});

}

</script>

</body>

</html>

