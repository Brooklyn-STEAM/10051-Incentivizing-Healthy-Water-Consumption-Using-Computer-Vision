<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white min-h-screen flex flex-col items-center">
{% include "components/navbar.html.jinja"%}

<section class="max-w-4xl w-full px-6 py-10 bg-blue-200 rounded-lg shadow mt-10 text-center">
<h1 class="text-3xl font-bold mt-4">Waterly Machine</h1>

<p class="mt-2 text-lg ">Points: {{ coins }}</p>

<!-- MACHINE -->
<div class="mt-6 relative">

    
    <img src="{{ url_for('static', filename='machine.png') }}" 
         class="w-80 mx-auto animate-pulse">

</div>

<!-- BUTTONS -->
<div class="flex gap-4 mt-6 text-center justify-center">

    <button onclick="spin(1)"
        class="bg-yellow-200 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105">
        10 Points • 1 Pull
    </button>

    <button onclick="spin(10)"
        class="bg-yellow-200 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105">
        100 Points • 10 Pulls
    </button>

</div>
</section>
<!-- RESULT MODAL -->
<div id="resultModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">

    <div class="bg-blue-200 p-6 rounded-xl text-center">
        <h2 class="text-xl font-bold mb-4">You Won!</h2>

        <img id="rewardImage" class="w-40 mx-auto mb-2">

        <p id="rewardName" class="font-bold"></p>

        <button onclick="closeModal()"
            class="mt-4 bg-blue-400 px-4 py-2 rounded">
            Close
        </button>
    </div>

</div>

<!-- REWARD CATALOG -->
<main class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-2 gap-10 rounded-lg shadow mt-10 w-full bg-blue-200">
    <h2 class="text-xl font-bold mb-4 text-center justify-center">All Rewards</h2>
    <div class="flex justify-center gap-5 flex-wrap col-span-full bg-blue-200 ">

        {% for reward in rewards_catalog %}
        <div class="bg-white rounded-lg shadow p-4 w-48 mx-2">
            <img src="{{ reward.Image }}" class="w-full h-24 object-cover">

            <p class="text-center mt-2 text-sm">{{ reward.Name }}</p>

        </div>
        {% endfor %}

    </div>
</main>

<script>

function spin(amount){

fetch("/gacha_spin",{
    method:"POST",
    headers:{
        "Content-Type":"application/json"
    },
    body:JSON.stringify({
        plays:amount
    })
})
.then(res => res.json())
.then(data => {

    if(data.success){

        let reward = data.rewards[0] // show first reward

        document.getElementById("rewardImage").src = reward.Image
        document.getElementById("rewardName").innerText = reward.Name

        document.getElementById("resultModal").classList.remove("hidden")

    } else {
        alert(data.message)
    }

})
.catch(err => alert(err))

}

function closeModal(){
    document.getElementById("resultModal").classList.add("hidden")
}
</script>
</body>
</html>