<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Friends — Daily Drip</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
  </style>
</head>
<body class="min-h-screen" style="background: #f0f7ff;">

{% include "components/navbar.html.jinja" %}

<div class="max-w-md mx-auto px-4 py-10">

  <!-- Header -->
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-sky-800">Friends</h1>
    <p class="text-sm text-sky-400 mt-1">Add friends and stay hydrated together</p>
  </div>

  <!-- Add friend card -->
  <div class="bg-white rounded-2xl p-6" style="box-shadow: 0 2px 12px rgba(0,0,0,.07);">
    <h2 class="text-base font-bold text-gray-700 mb-4">Add a Friend</h2>

    <form action="/addfriends" method="POST" class="flex flex-col gap-4">

      <div>
        <label for="user_id2" class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wide">
          Select a user
        </label>
        <select id="user_id2" name="user_id2"
                class="w-full border border-sky-200 rounded-xl px-4 py-2 text-sm text-gray-700 bg-sky-50 focus:outline-none focus:ring-2 focus:ring-sky-300">
          {% for x in User %}
            <option value="{{ x['ID'] }}">{{ x['Username'] }}</option>
          {% endfor %}
        </select>
      </div>

      <button type="submit"
              class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-2 rounded-xl text-sm transition">
        + Add Friend
      </button>

    </form>
  </div>

</div>
</body>
</html>