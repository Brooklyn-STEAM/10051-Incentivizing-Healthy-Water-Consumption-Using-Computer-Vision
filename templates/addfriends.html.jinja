<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

{% include "components/navbar.html.jinja"%}

 <body class="bg-gray-100 flex items-center justify-center min-h-screen">

<div class="flex items-center min-h-screen ">
 <div class="container mx-auto">
<div class="max-w-md mx-auto my-10 w-200">

 
 <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8 m-4">
        <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Add New Friend</h2>
        
        <form action="/addfriends" method="POST" class="space-y-4">
            <!-- Name Field -->
            <div>
        
                
                <label for="name" class="block text-sm font-medium text-gray-700">{{current_user.username}}</label>
            
               
               <br>
              
              
               <label for="user_id2" class="block text-sm font-bold text-gray-700">user_id2</label>
               <select id="user_id2" name="user_id2"
                    class="mt-1 block w-full pl-3 pr-10 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    {%for x in User %} 
                          <option value="{{x["ID"]}}">{{x["Username"]}}</option>
                   
                    {% endfor %}
                </select>
            
            </div>



            <!-- Submit Button -->
            <button type="submit"
                class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                Add Friend
            </button>
        </form>
    </div>
    

   
</body>

</html>
