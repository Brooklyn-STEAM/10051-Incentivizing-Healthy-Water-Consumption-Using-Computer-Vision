<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-blue-50">


    <div class="flex flex-col items-center justify-center min-h-screen">
      <h1 class="text-4xl font-bold mb-8">Wheel of Drinks</h1>
      <div class="w-64 h-64 rounded-full border-4 border-blue-500 flex items-center justify-center relative">
        {% for drink in drinks %}
          <div class="absolute text-center" style="transform: rotate({{ loop.index0 * (360 / drinks|length) }}deg) translate(0, -50%)">
            <span class="block text-sm font-semibold">{{ drink }}</span>
          </div>
        {% endfor %}
      </div>
    </div>








  </body>
  </html>
