<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-blue-50 flex items-center justify-center min-h-screen">

<<h1>Your Drinks</h1>

<main class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-2 gap-10">
{% for drink in rewards %}

<div style="flex justify-center">

<img src="{{ drink.Image }}" width="120">

<p>{{ drink.Name }}</p>

</div>

{% endfor %}

</main>

<br>

<a href="/wheelofdrinks">Pull Again</a>


</body>
</script>
</html>
