<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-cyan-100 to-blue-200 min-h-screen">

{% include "components/navbar.html.jinja"%}

<div class="flex items-center justify-center min-h-screen px-4">

    <div class="bg-white shadow-2xl rounded-3xl p-8 w-full max-w-md">

        <!-- HEADER -->
        <div class="text-center mb-6">

            <div class="text-6xl mb-3">
                💧
            </div>

            <h1 class="text-3xl font-bold text-blue-600">
                Hydration Group
            </h1>

            <p class="text-gray-500 mt-2">
                Add friends to track daily water intake
            </p>

        </div>

        <!-- WATER PROGRESS CARD -->
        <div class="bg-blue-50 rounded-2xl p-4 mb-6">

            <div class="flex justify-between mb-2">
                <span class="font-semibold text-blue-700">
                    Daily Goal
                </span>

               <span class="font-bold">{{ daily_goal }}</span>
            </div>

            <!-- PROGRESS BAR -->
            <div class="w-full bg-blue-200 rounded-full h-4">

                <div class="bg-blue-500 h-4 rounded-full w-3/4">
                </div>

            </div>

        </div>

        <!-- FORM -->
        <form method="POST" class="space-y-5">

            <div>

                <label class="block text-gray-700 font-semibold mb-2">
                    Select User
                </label>

                <select
                    name="user_id"
                    class="w-full border-2 border-blue-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-4 focus:ring-blue-300"
                >

                    {% for x in User %}

                        <option value="{{ x['ID'] }}">
                            {{ x['Username'] }}
                        </option>

                    {% endfor %}

                </select>

            </div>

            <!-- BUTTON -->
            <button
                type="submit"
                class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 rounded-xl shadow-lg transition duration-300"
            >
                + Add User To Group
            </button>

        </form>

        <!-- FOOTER STATS -->
        <div class="grid grid-cols-2 gap-4 mt-8">

            
               

            </div>

            <div class="bg-blue-50 rounded-xl p-4 text-center">

                <div class="text-2xl">
                    👥
                </div>

                <p class="text-sm text-gray-500">
                    Members
                </p>

                <h3 class="text-xl font-bold text-blue-600">
                    {{ User|length }}
                </h3>

            </div>

        </div>

    </div>

</div>

</body>
</html>


