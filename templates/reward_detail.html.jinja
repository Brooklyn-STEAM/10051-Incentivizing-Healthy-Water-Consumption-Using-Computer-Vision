<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ reward.Name }} — Daily Drip</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }

    .rarity-common    { background: #f3f4f6; color: #6b7280; }
    .rarity-uncommon  { background: #d1fae5; color: #059669; }
    .rarity-rare      { background: #dbeafe; color: #2563eb; }
    .rarity-epic      { background: #ede9fe; color: #7c3aed; }
    .rarity-legendary { background: linear-gradient(90deg,#fef3c7,#fed7aa); color: #b45309; }
  </style>
</head>
<body class="min-h-screen" style="background: #f0f7ff;">

{% include "components/navbar.html.jinja" %}

<div class="max-w-3xl mx-auto px-4 py-8">

  <!-- Back link -->
  <a href="/catalog" class="inline-flex items-center gap-1 text-sm text-sky-500 hover:text-sky-700 mb-6 transition">
    ← Back to My Drinks
  </a>

  <!-- Main card -->
  <div class="bg-white rounded-2xl overflow-hidden" style="box-shadow: 0 2px 20px rgba(14,165,233,.1);">

    <!-- Hero image -->
    <div class="w-full overflow-hidden bg-sky-50" style="max-height: 420px;">
      <img src="{{ reward.Image }}"
           alt="{{ reward.Name }}"
           class="w-full object-contain"
           style="max-height: 420px;" />
    </div>

    <!-- Content -->
    <div class="p-6 md:p-8">

      <!-- Name + badges -->
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-800 leading-snug">{{ reward.Name }}</h1>
          {% if reward.Timestamp %}
          <p class="text-xs text-sky-400 mt-1">
            💧 Earned {{ reward.Timestamp.strftime('%B %-d, %Y') }} at {{ reward.Timestamp.strftime('%-I:%M %p') }}
          </p>
          {% endif %}
        </div>

        <!-- Rarity badge -->
        {% if rarity %}
        <span class="text-xs font-bold px-3 py-1 rounded-full rarity-{{ rarity | lower }}"
              style="white-space: nowrap;">
          {% if rarity | lower == 'legendary' %}⭐
          {% elif rarity | lower == 'epic' %}💜
          {% elif rarity | lower == 'rare' %}💙
          {% elif rarity | lower == 'uncommon' %}💚
          {% else %}🩶{% endif %}
          {{ rarity }}
        </span>
        {% endif %}
      </div>

      <hr class="border-sky-100 mb-5" />

      <!-- Recipe -->
      <div>
        <h2 class="font-bold text-gray-700 text-base mb-3 flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-sky-100 flex items-center justify-center text-sky-500 text-xs">📋</span>
          Recipe
        </h2>
        <div class="bg-sky-50 rounded-xl p-4 text-sm text-gray-700 leading-relaxed whitespace-pre-line">{{ reward.Recipe }}</div>
      </div>

      <!-- Actions -->
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="/catalog"
           class="flex-1 text-center bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold py-2 px-4 rounded-xl transition">
          Back to My Drinks
        </a>
        <a href="/wheelofdrinks"
           class="flex-1 text-center bg-amber-400 hover:bg-amber-500 text-white text-sm font-semibold py-2 px-4 rounded-xl transition">
          🎰 Spin for More
        </a>
      </div>

    </div>
  </div>

</div>
</body>
</html>