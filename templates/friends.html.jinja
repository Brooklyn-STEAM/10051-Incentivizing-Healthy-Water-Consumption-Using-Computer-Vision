<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

{% include "components/navbar.html.jinja"%}



  <div class="flex items-center min-h-screen bg-white">
  <div class="container mx-auto">
  <div class="max-w-md mx-auto my-10">
    







<body class="bg-gray-100 p-4">
    <div class=" mx-auto bg-blue-200 shadow-lg rounded-lg p-4 h-180 w-180">
        <h1 class="text-2xl font-semibold mb-4">My Friends</h1> 


        <!-- Friends List -->
        <ul>
       {% for friend in friends %}
            
                <li class="p-3 hover:bg-gray-50 flex justify-between items-center" >
                   {{ friend.username }}
                     
                     <form action="/remove_friend/{{ friend.ID }}" method="POST" style="display:inline;">
            <button type="submit">Remove</button>
        </form>

                {{ friend[1] }} 
               {% if friend.is_online%}
                   <span style="color:green;">● Online</span>
                {% else %}
                    <span style="color:red;">● Offline</span>
               {% endif %}

                </li>
            {% endfor %}
        </ul>
       <a href="/addfriends"
           class=" inline bg-white border-2 border-blue-500 text-blue-500 px-3  py-2 rounded-full font-semibold hover:bg-blue-500 hover:text-white transition">
          Add+
        </a>
</div>

</div>

</div>


































</body>
