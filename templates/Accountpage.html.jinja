<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-b to-white min-h-screen flex items-center justify-center p-6">

{% include "components/navbar.html.jinja" %}

<div class="w-160 h-80 grid md:grid-cols-2 gap-6">

    <!-- PROFILE CARD -->
    <div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-75 w-80 -mt-50">

        <form method="POST" enctype="multipart/form-data">

            <!-- hidden file input -->
            <input type="file"
                   id="fileInput"
                   name="picture"
                   hidden
                   onchange="this.form.submit()">

            <!-- clickable profile image -->
            <img class="profile-pic h-35 w-35 rounded-full bg-white cursor-pointer"
                 src="{{ url_for('static', filename='profile_pics/' ~ (User.profile_image or 'default.jpg')) }}"
                 onclick="document.getElementById('fileInput').click()">

        </form>

        {% if current_user.is_authenticated %}
            <h1 class="text-center font-bold text-2xl text-white">
                Hi, {{ current_user.name }}
            </h1>
        {% endif %}

    </div>

    <!-- WATER CARD -->
    <div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-120 w-100 -mt-30 ml-30">

        <h1 class="font-bold text-2xl text-white">
            Water <br> Consumption
        </h1>

        <div class="w-80 h-100 bg-white rounded-xl"></div>

    </div>

    <!-- DAILY GOAL -->
    <div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-75 w-90 -mt-35">

        <h1 class="text-center font-bold text-2xl text-white">
            Daily Goal
        </h1>

        <p class="text-sky-700 font-semibold text-xl text-center">
            <span class="font-bold">{{ daily_goal }}</span> cups
        </p>

        <div class="w-70 h-85 bg-white"></div>

    </div>

</div>

</body>
</html>