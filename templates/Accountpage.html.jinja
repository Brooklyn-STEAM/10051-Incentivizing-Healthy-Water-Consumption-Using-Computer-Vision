<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-b to-white min-h-screen flex items-center justify-center p-6">
{% include "components/navbar.html.jinja"%}
  
<div class=" w-160 h-80 grid md:grid-cols-2 gap-6">

<div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-75 w-80 -mt-50">



 <div class="profile-pic-container">
 
    <form method="POST" enctype="multipart/form-data">
     <input type="file" id="fileInput" name="picture" style="display: none;">

    <img class="profile-pic h-35 w-35 rounded-full bg-white flex-center items-center justify-center"     src="{{ url_for('static', filename='profile_pics/' ~ (current_user.profile_image or 'default.jpg')) }}"width="100"
    onclick="document.getElementById('fileInput').click()">
    <button class="inline bg-white border-2 border-blue-500 text-blue-500 px-1  py-2 rounded-full font-semibold hover:bg-blue-500 hover:text-white transition" type="submit">Upload</button>
</form>
 </div>

    {%if not current_user.is_authenticated %}
 <a href="/login" class=" px-7 gap-2"></a>
    {%else%}
<h1 class="text-center font-bold text-2xl text-white">Hi, {{current_user.name}}</h1>
    {%endif%}

 </div>

<div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-120 w-100 -mt-30 ml-30">


<h1 class="font-bold text-2xl text-white">

Water 
<br>
Consummtion
</h1>
 <div class="w-80 h-100 bg-white rounded-xl">
<span class="text-blue-200 text-center font-bold"></span>
 </div>
 </div>


<div class="bg-blue-300 rounded-[40px] shadow-xl p-8 flex flex-col justify-between h-75 w-90 -mt-35">

<h1 class="text-center font-bold text-2xl text-white">Daily Goal</h1>
<p class="text-sky-700 font-semibold text-xl">
           <span class="font-bold">{{ daily_goal }}</span> cups
        </p>


<br>
<div class="w-70 h-85 bg-white rounded-none">
<span class="text-blue-200 text-center font-bold"></span>
</div>





 </body>