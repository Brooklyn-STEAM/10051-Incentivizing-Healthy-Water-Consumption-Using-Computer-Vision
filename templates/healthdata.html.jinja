<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-blue-50">

 

  {% for message in get_flashed_messages() %}
    <div class="text-red-600 text-center mt-2">{{ message }}</div>
  {% endfor %}

<form method="POST" action="{{ url_for('healthdata') }}" class="flex flex-col gap-4 max-w-md mx-auto p-6 bg-white shadow-lg rounded-xl mt-6">
    <h1 class="text-2xl font-bold text-center text-blue-600">Let's create an Account Water Goal</h1>


    <label for="age">Age</label>
    <input
      type="date"
      name="Age"
      id="birthday"
      required
      class="border px-3 py-2 rounded"
    />

  
    <label for="weight">Weight (lbs)</label>
    <input
      type="number"
      name="Weight"
      id="weight"
      required
      placeholder="Enter your weight in lbs"
      class="border px-3 py-2 rounded"
    />


    <label class="font-medium">Sex</label>
    <div class="flex gap-4">
      <label>
        <input type="radio" name="Sex" value="female" required>
        Female
      </label>

      <label>
        <input type="radio" name="Sex" value="male">
        Male
      </label>

      <label>
        <input type="radio" name="Sex" value="prefer_not">
        Prefer not to say
      </label>
    </div>

    <label class="font-medium">How active are you?</label>
    <div class="flex flex-col gap-1">
      <label>
        <input type="radio" name="Active level" value="not_active" required>
        Not very active
      </label>

      <label>
        <input type="radio" name="Active level" value="moderate">
        Moderately active
      </label>

      <label>
        <input type="radio" name="Active level" value="very_active">
        Very active
      </label>
    </div>

   
    <label class="font-medium">How much do you exercise daily?</label>
    <div class="flex flex-col gap-1">
      <label>
        <input type="radio" name="Daily Excersize" value="0_30" required>
        0–30 minutes
      </label>

      <label>
        <input type="radio" name="Daily Excersize" value="30_60">
        30–60 minutes
      </label>

      <label>
        <input type="radio" name="Daily Excersize" value="1_2">
        1–2 hours
      </label>

      <label>
        <input type="radio" name="Daily Excersize" value="2_plus">
        2+ hours
      </label>
    </div>

   
    <label class="font-medium">What’s the usual weather like?</label>
    <div class="flex gap-4">
      <label>
        <input type="radio" name="Climate" value="cold" required>
        Cold
      </label>

      <label>
        <input type="radio" name="Climate" value="mild">
        Mild
      </label>

      <label>
        <input type="radio" name="Climate" value="hot">
        Hot
      </label>
    </div>

    <label class="font-medium">Health considerations (optional)</label>
    <div class="flex flex-col gap-1">
      <label>
        <input type="checkbox" name="Health" value="kidney">
        Kidney problems
      </label>

      <label>
        <input type="checkbox" name="Health" value="heart">
        Heart condition
      </label>

      <label>
        <input type="checkbox" name="Health" value="sick">
        Currently sick
      </label>

      <label>
        <input type="checkbox" name="Health" value="none">
        None of the above
      </label>
    </div>

    <p class="text-xs text-gray-500">
      <strong class="text-red-500">If you have a medical condition affecting fluid intake, follow your doctor’s advice.</strong>
    </p>
 
    <button
      type="submit"
      class="bg-blue-600 text-white rounded px-4 py-2 mt-4 hover:bg-blue-700"
    >
      Set up your account
    </button>

    <a href="/login"
       class="block text-center text-blue-600 font-medium hover:underline">
       Have an account? Login
    </a>

  </form>

  </body>
</html>













