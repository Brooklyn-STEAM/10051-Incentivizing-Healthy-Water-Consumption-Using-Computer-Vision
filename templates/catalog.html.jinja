<h1>My Drinks 💧</h1>

<div class="grid md:grid-cols-3 gap-6">
  {% for r in rewards %}
  <a href="{{ url_for('reward_detail', reward_id=r.ID) }}"
     class="bg-white rounded-lg shadow p-4 hover:shadow-lg transition">
    <img src="{{ r.Image }}" class="w-full h-32 object-cover rounded">
    <h3 class="mt-2 font-bold text-lg">{{ r.Name }}</h3>
    <p class="text-sm mt-1">Price: {{ r.Price }}</p>
    <p class="text-xs text-gray-500 mt-1">Weight: {{ r.Weight }}</p>
    <p class="text-xs text-gray-400 mt-1">
      Obtained: {{ r.Timestamp }}
    </p>
  </a>
  {% endfor %}
</div>
