<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Drinks — Daily Drip</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
    .drink-card img { transition: transform .35s ease; }
    .drink-card:hover img { transform: scale(1.06); }
    .drink-card { transition: box-shadow .2s ease, transform .2s ease; }
    .drink-card:hover { box-shadow: 0 8px 28px rgba(14,165,233,.15); transform: translateY(-2px); }
  </style>
</head>
<body class="min-h-screen" style="background: #f0f7ff;">

{% include "components/navbar.html.jinja" %}

{% with messages = get_flashed_messages() %}
  {% if messages %}
    <div class="max-w-7xl mx-auto mt-4 px-4">
      {% for msg in messages %}
        <div class="bg-green-100 border border-green-300 text-green-800 px-4 py-2 rounded-xl mb-2 text-sm">{{ msg }}</div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- HEADER -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-sky-800">My Drink Collection</h1>
      <p class="text-sm text-sky-500 mt-1">
        {% if rewards %}
          {{ rewards | length }} drink{% if rewards | length != 1 %}s{% endif %} earned
        {% else %}
          No drinks yet — start spinning!
        {% endif %}
      </p>
    </div>
    <a href="/wheelofdrinks"
       class="bg-amber-400 hover:bg-amber-500 text-white text-sm font-semibold px-4 py-2 rounded-xl transition">
      🎰 Spin for More
    </a>
  </div>

  <!-- DRINK GRID -->
  {% if rewards %}
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">
    {% for r in rewards %}
    <a href="{{ url_for('reward_detail', reward_id=r.ID) }}"
       class="drink-card bg-white rounded-2xl overflow-hidden flex flex-col"
       style="box-shadow: 0 2px 12px rgba(0,0,0,.07);">

      <!-- Image -->
      <div class="overflow-hidden bg-sky-50" style="aspect-ratio: 1 / 1;">
        <img src="{{ r.Image }}" alt="{{ r.Name }}" class="w-full h-full object-cover" />
      </div>

      <!-- Info -->
      <div class="p-3 flex flex-col gap-1 flex-1">
        <h3 class="font-bold text-gray-800 text-sm leading-snug">{{ r.Name }}</h3>
        <div class="mt-auto pt-2 flex items-center gap-1">
          <span class="text-sky-300 text-xs">💧</span>
          <span class="text-xs text-sky-400">
            Earned
            {% if r.Timestamp %}
              {{ r.Timestamp.strftime('%b %-d') }} at {{ r.Timestamp.strftime('%-I:%M %p') }}
            {% endif %}
          </span>
        </div>
      </div>

    </a>
    {% endfor %}
  </div>

  {% else %}
  <!-- Empty state -->
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="w-20 h-20 rounded-full flex items-center justify-center mb-5"
         style="background: linear-gradient(135deg,#e0f0ff,#bae6fd);">
      <span class="text-4xl">🧃</span>
    </div>
    <h2 class="text-lg font-bold text-gray-600 mb-1">Your collection is empty</h2>
    <p class="text-sm text-gray-400 mb-6 max-w-xs">Spin the wheel and win drinks to fill up your collection!</p>
    <a href="/wheelofdrinks"
       class="bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold px-6 py-2 rounded-xl transition">
      Go Spin Now
    </a>
  </div>
  {% endif %}

</div>
</body>
</html>